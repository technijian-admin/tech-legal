{
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:technijian.com)",
      "Bash(pip install pypdf pdfplumber)",
      "Read(//tmp/**)",
      "Bash(npm list -g docx)",
      "Bash(npm install -g docx)",
      "Bash(node templates/generate-docx.js)",
      "Bash(npm install docx)",
      "Bash(pip install python-docx)",
      "Bash(python -c \":*)",
      "WebSearch",
      "WebFetch(domain:developers.docusign.com)",
      "WebFetch(domain:www.docusign.com)",
      "WebFetch(domain:community.docusign.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:zapier.com)",
      "Bash(pip install composio-core python-dotenv)",
      "Bash(export COMPOSIO_API_KEY=\"ak_HZZxYn8_ysJ7eC__oX0t\")"
    ],
    "additionalDirectories": [
      "C:\\Users\\rjain\\.claude\\projects\\c--VSCode-tech-legal-tech-legal",
      "\\tmp\\tech-branding\\assets",
      "C:\\Users\\rjain\\OneDrive - Technijian, Inc\\Documents\\obsidian\\tech-legal"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/vault-inject.cjs\"",
            "timeout": 8,
            "statusMessage": "Loading vault memory..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/impact-check.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/reindex.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/vault-capture.cjs\"",
            "timeout": 8,
            "statusMessage": "Saving turn to vault..."
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/preference-extract.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/health-check.cjs\"",
            "timeout": 10,
            "statusMessage": "Refreshing vault HEALTH.md..."
          }
        ]
      }
    ]
  }
}
