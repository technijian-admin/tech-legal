{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Server": {
    "BindUrls": "https://+:8443"
  },
  "Auth": {
    "ApiToken": "REPLACE-WITH-BEARER-TOKEN"
  },
  "Qb": {
    "CompanyFilePath": "C:\\path\\to\\company.QBW",
    "AppId": "REPLACE-WITH-APP-ID",
    "AppName": "QbConnectService",
    "OwnerIdZero": false
  },
  "Safety": {
    "AllowWrites": false
  },
  "QbXml": {
    "Version": "16.0"
  },
  "Audit": {
    "Path": "C:\\ProgramData\\QbConnectService\\audit"
  },
  "Request": {
    "TimeoutSeconds": 60
  }
}
