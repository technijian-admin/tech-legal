# QbConnectService client config. Copy to .env (gitignored) and fill in.
QB_API_BASE_URL=https://10.120.254.13:8443
QB_API_TOKEN=REPLACE-WITH-THE-BEARER-TOKEN-FROM-INSTALL-RESULT-TXT-ON-QB-HOST

# Self-signed cert: false skips TLS verification. Alternatively give a path to a CA
# bundle / .cer (recommended for production; trust the cert at LocalMachine\Root
# and leave this as true).
QB_VERIFY_TLS=false

# Multi-tenant default company. The service multiplexes 4 .QBW files; this key picks
# the default when a request omits ?company=. Per-call override is supported via
# `client.with_company("...")` or the `company=` kwarg on op/dryrun/qbxml.
# Available keys (as of 2026-05-19): technijian (default + only fully authorized),
# electronic-corporation-of-america, technijian-pvt-ltd, kutumba-holdings-llc.
QB_DEFAULT_COMPANY=technijian

QB_TIMEOUT=60
QB_RETRIES=3
