# QbConnectService client config. Copy to .env (gitignored) and fill in.
QB_API_BASE_URL=https://localhost:8443
QB_API_TOKEN=REPLACE-WITH-THE-BEARER-TOKEN-FROM-appsettings-Auth-ApiToken
# Self-signed dev cert: set false to skip TLS verification (or give a path to a CA bundle / .cer).
QB_VERIFY_TLS=false
QB_TIMEOUT=60
QB_RETRIES=3
